<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MyDICollection.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MyDICollection.MainPage"
             xmlns:helpers="clr-namespace:MyDICollection.Helpers"
             Title="{helpers:Translate Title}"
             xmlns:responsive="clr-namespace:MyDICollection.Helpers.Responsive">

    <Grid RowDefinitions="Auto,*">

        <!-- Sección de filtros -->
        <Border Grid.Row="0"
                Margin="{responsive:ResponsiveThickness BaseValue='15,15,15,0'}"
                Style="{StaticResource FilterBorder}">

            <toolkit:Expander>
                
                <toolkit:Expander.Header>
                    
                    <Grid 
                        ColumnDefinitions="*,Auto"
                        Padding="{responsive:ResponsiveThickness BaseValue='14,10'}">
                        
                        <Label Text="{helpers:Translate Filters}"
                               Style="{StaticResource FilterTitleLabel}"
                               VerticalOptions="Center"
                               HorizontalOptions="Start"/>
                        
                    </Grid>
                    
                </toolkit:Expander.Header>

                <VerticalStackLayout 
                    Padding="{responsive:ResponsiveThickness BaseValue='14,4,14,14'}"
                    Spacing="{responsive:ResponsiveSize BaseValue=10}">

                    <VerticalStackLayout Spacing="{responsive:ResponsiveSize BaseValue=2}">
                        <Label Text="{helpers:Translate Collect}" FontSize="12" TextColor="Gray"/>
                        <Picker ItemsSource="{Binding OpcionesObtenido}"
                                SelectedItem="{Binding FiltroObtenido}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="{responsive:ResponsiveSize BaseValue=2}">
                        <Label Text="{helpers:Translate Type}" FontSize="12" TextColor="Gray"/>
                        <Picker ItemsSource="{Binding OpcionesTipo}"
                                SelectedItem="{Binding FiltroTipo}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="{responsive:ResponsiveSize BaseValue=2}">
                        <Label Text="{helpers:Translate Version}" FontSize="12" TextColor="Gray"/>
                        <Picker ItemsSource="{Binding OpcionesVersion}"
                                SelectedItem="{Binding FiltroVersion}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="{responsive:ResponsiveSize BaseValue=2}">
                        <Label Text="{helpers:Translate Brand}" FontSize="12" TextColor="Gray"/>
                        <Picker ItemsSource="{Binding OpcionesFranquicia}"
                                SelectedItem="{Binding FiltroFranquicia}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </toolkit:Expander>
        </Border>

        <!-- Loader -->
        <ActivityIndicator Grid.Row="1"
                            IsRunning="{Binding IsBusy}"
                            IsVisible="{Binding IsBusy}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

        <!-- Lista de figuras -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Figures}"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Margin="{responsive:ResponsiveThickness BaseValue='15'}"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never">
            
            <CollectionView.ItemsLayout>
                
                <LinearItemsLayout 
                    Orientation="Vertical" 
                    ItemSpacing="{responsive:ResponsiveSize BaseValue=12}"/>
                
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                
                <DataTemplate x:DataType="models:FiguraModel">
                    
                    <Grid 
                        Padding="{responsive:ResponsiveThickness BaseValue='0,10,10,0'}">
                        
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                Padding="{responsive:ResponsiveThickness BaseValue='12'}"
                                BackgroundColor="White">

                            <Grid 
                                ColumnDefinitions="Auto,*" 
                                ColumnSpacing="{responsive:ResponsiveSize BaseValue=14}">

                                <Border Grid.Column="0"
                                        StrokeShape="RoundRectangle 12"
                                        HeightRequest="{responsive:ResponsiveSize BaseValue=90}"
                                        WidthRequest="{responsive:ResponsiveSize BaseValue=90}"
                                        Padding="0">
                                    
                                    <Image Source="{Binding ImagenUrl}"
                                           Aspect="AspectFit"
                                           HeightRequest="{responsive:ResponsiveSize BaseValue=85}"
                                           WidthRequest="{responsive:ResponsiveSize BaseValue=85}"/>
                                </Border>

                                <VerticalStackLayout 
                                    Grid.Column="1" 
                                    Spacing="{responsive:ResponsiveSize BaseValue=2}" 
                                    VerticalOptions="Center">

                                    <Label Text="{Binding Nombre}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"/>

                                    <Label FontSize="13" TextColor="Gray">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Tipo}" />
                                                <Span Text=" · v" />
                                                <Span Text="{Binding Version}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Label Text="{Binding Franquicia}"
                                           FontSize="13"
                                           TextColor="#EB1937"
                                           FontAttributes="Italic"/>

                                    <HorizontalStackLayout 
                                        Spacing="{responsive:ResponsiveSize BaseValue=10}" 
                                        Margin="{responsive:ResponsiveThickness BaseValue='0,8,0,0'}">
                                        
                                        <Button Text="－"
                                                FontAttributes="Bold"
                                                WidthRequest="40"
                                                HeightRequest="36"
                                                Padding="0"
                                                CornerRadius="18"
                                                BackgroundColor="#E0E0E0"
                                                TextColor="Black"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DecrementarCommand}"
                                                CommandParameter="{Binding .}"/>

                                        <Button Text="＋"
                                                FontAttributes="Bold"
                                                WidthRequest="40"
                                                HeightRequest="36"
                                                Padding="0"
                                                CornerRadius="18"
                                                BackgroundColor="#EB1937"
                                                TextColor="White"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IncrementarCommand}"
                                                CommandParameter="{Binding .}"/>

                                        <Button Text="🌐"
                                                FontSize="16"
                                                WidthRequest="40"
                                                HeightRequest="36"
                                                Padding="0"
                                                CornerRadius="18"
                                                BackgroundColor="#FFA000"
                                                TextColor="White"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirWikiCommand}"
                                                CommandParameter="{Binding .}"/>
                                        
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>
                                
                            </Grid>
                            
                        </Border>

                        <Border IsVisible="{Binding Obtenido}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#2E7D32"
                                Padding="{responsive:ResponsiveThickness BaseValue='10,5'}"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="{responsive:ResponsiveThickness BaseValue='0,-10,-10,0'}"
                                StrokeThickness="0">
                            
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.3" Radius="6" Offset="0,2"/>
                            </Border.Shadow>
                            
                            <Label Text="{Binding Cantidad, StringFormat='✓ x{0}'}"
                                   TextColor="White"
                                   FontSize="12"
                                   FontAttributes="Bold"/>
                            
                        </Border>

                        <Border IsVisible="{Binding Obtenido, Converter={StaticResource InvertedBoolConverter}}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#C62828"
                                WidthRequest="28"
                                HeightRequest="28"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="{responsive:ResponsiveThickness BaseValue='0,-10,-10,0'}"
                                Padding="0"
                                StrokeThickness="0">
                            
                            <Border.Shadow>
                                
                                <Shadow Brush="Black" Opacity="0.3" Radius="6" Offset="0,2"/>
                                
                            </Border.Shadow>
                            
                            <Label Text="0"
                                   TextColor="White"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                            
                        </Border>
                        
                    </Grid>
                    
                </DataTemplate>
                
            </CollectionView.ItemTemplate>

        </CollectionView>
        
    </Grid>
    
</ContentPage>