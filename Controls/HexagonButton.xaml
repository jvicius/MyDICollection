<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyDICollection.Controls.HexagonButton"
             x:Name="RootControl">

    <Grid>
        <!-- Stretch="Uniform" obliga a MAUI a mantener la proporción perfecta del hexágono
         sin importar si el contenedor es rectangular -->
        <Path Data="M 25,0 L 75,0 L 100,50 L 75,100 L 25,100 L 0,50 Z"
              Fill="{Binding HexBackgroundColor, Source={x:Reference RootControl}}"
              Stroke="{Binding HexBorderColor, Source={x:Reference RootControl}}"
              StrokeThickness="2"
              Aspect="Uniform" 
              HorizontalOptions="Center"
              VerticalOptions="Center" />

        <!-- Aseguramos que el texto esté en el mero centro matemático -->
        <Label Text="{Binding Text, Source={x:Reference RootControl}}"
           TextColor="{Binding TextColor, Source={x:Reference RootControl}}"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           FontAttributes="Bold" 
           FontSize="18"/>
    </Grid>

    <ContentView.GestureRecognizers>
        <!-- Solo escuchamos el evento Tapped -->
        <TapGestureRecognizer Tapped="OnTapped" />
    </ContentView.GestureRecognizers>


</ContentView>
